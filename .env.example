# production: find on Cloudflare. if the signing key is entirely lost, you can generate a new one and replace the one currently in use.
# development: just set to some consistent string on both the website and worker 
WORKER_SIGNING_KEY=unset

# production: set to the URL of the deployed worker
# development: get this from the output of running `npx wrangler dev` on the worker repo
WORKER_URL="http://127.0.0.1.8787"
